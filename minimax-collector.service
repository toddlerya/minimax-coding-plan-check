[Unit]
Description=MiniMax Coding Plan Collector
After=network.target

[Service]
Environment=PYTHONUNBUFFERED=1
Environment=ALL_PROXY=socks5://127.0.0.1:7897
Environment=HTTPS_PROXY=http://127.0.0.1:7897
Type=simple
User=evi1
WorkingDirectory=/home/evi1/minimax-coding-plan-check
ExecStart=/usr/bin/python3 /home/evi1/minimax-coding-plan-check/collector.py
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
